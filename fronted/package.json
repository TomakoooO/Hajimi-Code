{
  "name": "fronted",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.vue --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.4.37"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitejs/plugin-vue": "^5.1.2",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-vue": "9.28.0",
    "husky": "^9.1.7",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vue-eslint-parser": "9.4.3",
    "vue-tsc": "^2.0.29"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,vue}": [
      "eslint --fix"
    ],
    "*.{css,scss,html,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
